/**
 * IDENTITY: Database Schema for Nash Solver & ICM Lab
 * PATH: prisma/schema.prisma
 * ROLE: Define a estrutura relacional para armazenar dados de teoria dos jogos de poker,
 *       incluindo spots, estrategias, stacks de jogadores e detalhes de torneio,
 *       para suportar calculos de ICM, analise de Risk Premium e solucoes GTO.
 * BINDING: [Laboratorio de ICM Universal (V2), @implementor, @auditor, Python DAL,
 *           Frontend (Next.js/React para visualizacao de dados), @validador]
 * TELEOLOGY: Evoluir para suportar percursos complexos em arvores de jogo, simulacoes FGS,
 *            e integracao com dados de solvers externos (DeepSolver, GTOWizard).
 */

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==============================================================================
// Entidades Essenciais: Torneio e Estrutura de Premiacao para Calculos ICM/Risk Premium
// ==============================================================================

model Tournament {
  id               String           @id @default(cuid())
  name             String
  buy_in           Float
  total_prize_pool Float
  start_date       DateTime         @default(now())
  status           String           @default("active") // active, completed, cancelled

  payoutStructure PayoutStructure[]
  scenarios       TournamentScenario[]
}

model PayoutStructure {
  id           String    @id @default(cuid())
  tournamentId String
  rank         Int
  percentage   Float // e.g., 0.50 para 50%
  amount       Float // valor calculado para acesso rapido

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, rank])
}

// ==============================================================================
// Dados de Referencia: Tabelas de Consulta Estaticas para Contexto do Jogo
// ==============================================================================

model GameType {
  id   String @id @default(cuid())
  name String @unique // e.g., 'No-Limit Holdem', 'Pot-Limit Omaha'
  spots Spot[]
}

model Position {
  id   String @id @default(cuid())
  name String @unique // e.g., 'UTG', 'BTN', 'SB', 'BB', 'CO', 'MP'
  spots Spot[]
}

model Street {
  id   String @id @default(cuid())
  name String @unique // e.g., 'Preflop', 'Flop', 'Turn', 'River'
  spots Spot[]
}

model ActionType {
  id   String @id @default(cuid())
  name String @unique // e.g., 'Fold', 'Check', 'Call', 'Bet', 'Raise'
  // Futuro: Poderia adicionar 'value_type' (e.g., 'fixed', 'percentage_pot', 'to_N_bb')
  spotFlows     SpotFlow[]
  strategyActions StrategyAction[]
}

// ==============================================================================
// Modelo de Jogador - Para jogadores genericos em cenarios. Pode ser estendido para usuarios.
// ==============================================================================

model Player {
  id   String @id @default(cuid())
  name String @unique // e.g., "Hero", "Villain 1", "SB Player", "Player 3"
  // Para jogadores simulados, um nome simples e suficiente.
  // Para usuarios reais da plataforma, isso seria estendido para incluir detalhes do usuario.

  spotsToAct     Spot[] @relation("PlayerToAct")
  playerStacks   PlayerStackAtSpot[]
  strategies     Strategy[]
}

// ==============================================================================
// Estado do Jogo e Arvore de Decisao: Spots, Fluxos, Stacks, Estrategias
// ==============================================================================

model TournamentScenario {
  id           String    @id @default(cuid())
  tournamentId String
  name         String? // e.g., "Mesa Final 3-Handed"
  description  String?
  initial_stacks Json? // Stacks iniciais para todos os jogadores neste cenario (JSON array de objetos {playerId, stack_size}).
  
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  spots        Spot[]
}

model Spot {
  id                     String             @id @default(cuid())
  scenarioId             String // Liga a um contexto de torneio especifico
  parentFlowId           String? // O SpotFlow que levou a este Spot (nulo para spots iniciais)
  playerToActId          String // ID do jogador que esta tomando uma decisao neste spot
  positionToActId        String? // Posicao do jogador a agir
  streetId               String
  pot_size_before_action Float
  board_cards            String? // String JSON: '["As", "Kd", "7h"]' ou '["As", "Kd", "7h", "2c"]'
  gameTypeId             String? // Assumindo que um Spot pertence a um GameType para regras

  // Relacionamentos
  scenario             TournamentScenario @relation(fields: [scenarioId], references: [id])
  parentFlow           SpotFlow?          @relation("NextSpotFromSpotFlow", fields: [parentFlowId], references: [id])
  playerToAct          Player             @relation("PlayerToAct", fields: [playerToActId], references: [id])
  positionToAct        Position?          @relation(fields: [positionToActId], references: [id])
  street               Street             @relation(fields: [streetId], references: [id])
  gameType             GameType?          @relation(fields: [gameTypeId], references: [id])

  playerStacksAtSpot PlayerStackAtSpot[]
  spotFlows          SpotFlow[]           @relation("CurrentSpot") // As acoes que podem ser tomadas a partir deste spot
  strategies         Strategy[]
}

model SpotFlow {
  id               String      @id @default(cuid())
  currentSpotId    String
  actionTypeId     String
  action_value     String? // e.g., "10bb", "pot", "all_in". String para flexibilidade.
  frequency        Float       // Com que frequencia esta acao e tomada (0.0 a 1.0)

  // Liga ao proximo estado (Spot) ou nulo se for um no terminal
  nextSpot         Spot?       @relation("NextSpotFromSpotFlow")
  nextSpotId       String?

  currentSpot      Spot        @relation("CurrentSpot", fields: [currentSpotId], references: [id])
  actionType       ActionType  @relation(fields: [actionTypeId], references: [id])
}

model PlayerStackAtSpot {
  id           String @id @default(cuid())
  spotId       String
  playerId     String // Representa o ID unico do jogador neste cenario
  stack_size   Float

  spot   Spot   @relation(fields: [spotId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@unique([spotId, playerId]) // Um jogador so pode ter uma stack em um spot especifico
}

// ==============================================================================
// Resultados do Solver: Estrategias e Valores Esperados (EV)
// ==============================================================================

model Strategy {
  id        String   @id @default(cuid())
  spotId    String
  playerId  String   // O jogador para quem esta estrategia e otima
  ev_total  Float    // EV total para este jogador neste spot, considerando a estrategia otima
  timestamp DateTime @default(now()) // Quando esta estrategia foi computada/armazenada

  spot            Spot             @relation(fields: [spotId], references: [id])
  player          Player           @relation(fields: [playerId], references: [id])
  strategyActions StrategyAction[]
}

model StrategyAction {
  id              String     @id @default(cuid())
  strategyId      String
  actionTypeId    String
  action_value    String? // e.g., "10bb", "pot", "all_in"
  frequency       Float      // 0.0 a 1.0, para estrategias mistas
  ev_contribution Float      // EV contribuido ao tomar esta acao especifica

  strategy   Strategy   @relation(fields: [strategyId], references: [id])
  actionType ActionType @relation(fields: [actionTypeId], references: [id])

  @@unique([strategyId, actionTypeId, action_value]) // Uma estrategia tem acoes unicas
}
