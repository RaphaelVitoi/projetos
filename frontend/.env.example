# PokerRacional — Variáveis de Ambiente
# Copiar para .env.local para desenvolvimento local
# Configurar no painel Vercel para produção

# Banco de dados (SQLite local / Postgres em produção)
# Desenvolvimento: file:./prisma/dev.db
# Produção: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="file:./prisma/dev.db"

# URL base da aplicação
NEXT_PUBLIC_APP_URL="https://pokerracional.com"

# Analytics (Vercel Analytics — ativar no painel Vercel)
# Não requer variável de ambiente adicional se usar @vercel/analytics

# Opcional: Google Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
